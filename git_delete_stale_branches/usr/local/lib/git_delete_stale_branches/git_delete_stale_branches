#! /usr/bin/env bash
#
# Parse CLI arguments defined in a recfile and put them in an associative
# array.

function is_docker() {
    local cgroup=/proc/1/cgroup
    test -f "$cgroup"
    grep -E ':cpuset:/docker' -- "$cgroup" > /dev/null 2>&1
}

function _csv_two_header() {
    printf 'timestamp_delete_if_commit_is_older,branch'
}

function _csv_three_header() {
    printf 'timestamp_delete_if_commit_is_older,branch,timestamp_delete_after'
}

function _csv_n_distinct_fields() {
    validate_number_of_arguments 1 $@
    local csv_file="${1}"
    gawk --csv '
BEGIN { fields = 0; first = 1; exit_now = 0 }
{
    if (NF != fields && first == 0) {
        if (fields == 0) {
            fields = NF
        } else {
            print "CSV has inconsistent number of fields: " fields " vs " NF > "/dev/stderr"
            exit_now = 1
            exit 1
        }
    }
    fields = NF
    first = 0
}
END {
    # `END` executes even after `exit 1`.
    if (exit_now == 0) print fields
}
    ' "${csv_file}"
}

function is_valid_simple_csv() {
    validate_number_of_arguments 1 $@
    local csv_file="${1}"

    # Get number of fields consistently used in the file
    local n_fields=$(_csv_n_distinct_fields "${csv_file}")

    # If we got "mixed", the file has inconsistent number of fields
    if [[ ${n_fields} == "mixed" ]]; then
        return 1
    fi

    # For 2-field CSVs: no header required, just check field count
    if [[ ${n_fields} == "2" ]]; then
        # Verify all lines match expected format (timestamp,branch)
        gawk --csv '
        NF == 2 && $1 ~ /^[0-9]+$/ {next}
        {exit 1}
        ' "${csv_file}" || return 1
        return 0
    fi

    # For 3-field CSVs: require header and validate format
    if [[ ${n_fields} == "3" ]]; then
        # First get the expected header
        local expected_header
        expected_header="$(_csv_three_header)"

        # Validate header and data format
        gawk --csv -v expected="${expected_header}" '
        NR == 1 {
            # Check header matches expected
            if ($0 != expected) {
                exit 1
            }
            next
        }
        NF == 3 && $1 ~ /^[0-9]+$/ && $3 ~ /^[0-9]+$/ {next}
        {exit 1}
        ' "${csv_file}" || return 1
        return 0
    fi

    # Any other number of fields is invalid
    return 1
}

function validate_number_of_arguments() {
    # Get the number of arguments excluding the last one
    local n_args_received="$(($# - 1))"
    # Get the last argument
    local n_args_expected="${1:-0}"

    if ((n_args_received != n_args_expected)); then
        echo "Expected ${n_args_expected} arguments, but got ${n_args_received}." >&2
        return 1
    fi
}

